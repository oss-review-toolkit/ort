{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>oss-review-toolkit/.github//renovate-config",
    "docker:disable"
  ],
  "ignorePaths": [
    "plugins/reporters/web-app-template",
    "**/src/funTest/assets/**",
    "**/src/test/assets/**"
  ],
  "packageRules": [
    {
      "matchManagers": ["gradle"],
      "commitMessageTopic": "{{depName}}",
      "recreateWhen": "never"
    },
    {
      "matchPackageNames": [
        "com.atlassian.jira:jira-rest-java-client-api",
        "com.atlassian.jira:jira-rest-java-client-app"
      ],
      "allowedVersions": "/^[0-9]+\\.[0-9]+\\.[0-9]+$/"
    },
    {
      "matchPackageNames": [
        "org.jruby:jruby"
      ],
      "allowedVersions": "/^9\\.[0-9]+\\.[0-9]+(\\.[0-9]+)?$/"
    },
    {
      "matchPackageNames": [
        "software.amazon.awssdk:*"
      ],
      "matchUpdateTypes": ["patch"],
      "schedule": "after 9pm on wednesday"
    },
    {
      "matchManagers": ["npm"],
      "rangeStrategy": "pin",
      "schedule": "after 9pm on wednesday"
    }
  ],
  "nuget": {
    "enabled": false
  }
}
